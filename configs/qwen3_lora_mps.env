# Qwen3-0.6B LoRA training defaults (MPS-friendly)
: "${NUM_TRAIN_EPOCHS:=1}"
: "${PER_DEVICE_TRAIN_BATCH_SIZE:=1}"
: "${GRADIENT_ACCUMULATION_STEPS:=4}"
: "${LEARNING_RATE:=1e-4}"
: "${MAX_LENGTH:=256}"
: "${LOGGING_STEPS:=1}"
: "${SAVE_STEPS:=20}"
: "${SAVE_TOTAL_LIMIT:=2}"
: "${NUM_PERTURB_SAMPLES:=32}"
: "${GAMMA:=100}"
: "${SIGMA_EPS:=1e-6}"
: "${K_NEIGHBORS:=100}"
: "${TARGET_MODULES:=q_proj,k_proj,v_proj,o_proj}"
